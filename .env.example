# Copy to .env (install.sh does this automatically). The scripted floor needs nothing here.
# Backend selection order: HA_BACKEND > GEMINI_API_KEY > OPENAI_API_KEY > Ollama > scripted.

HA_BACKEND=scripted          # scripted | ollama | gemini | openai

# Live backends (Milestone 2 — leave blank for the offline scripted floor):
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
