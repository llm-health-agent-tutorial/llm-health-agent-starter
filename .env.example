# Copy to .env (install.sh does this automatically). The scripted floor needs nothing here.
# Backend selection order (HA_BACKEND=auto runs the detection chain):
#   HA_BACKEND > GEMINI_API_KEY > OPENAI_API_KEY > local Ollama > scripted (always-available floor).
# Core notebooks pin scripted explicitly; the optional "try live" cell + ha-check use this config.
# Live backends need the SDKs: run `make live-install` (ha-check prints the exact fix).

HA_BACKEND=auto              # auto | scripted | ollama | gemini | openai

# Live backends (leave blank for the offline scripted floor):
# GEMINI_API_KEY=            # or GOOGLE_API_KEY (the google-genai SDK's native variable) — either works
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini-2024-07-18
# OPENAI_BASE_URL=
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
